{
  "expo": {
    "name": "SuperCart Guard",
    "slug": "supercart-guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1F3A"
    },
    "ios": {
      "bundleIdentifier": "com.supercart.guard",
      "supportsTablet": false
    },
    "android": {
      "package": "com.supercart.guard",
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "ed2118d7-f7d0-4af4-9631-ecfe1fc0cede"
      }
    },
    "owner": "supercart"
  }
}
